{
    "name": "rashart/sunat-sender",
    "description": "Paquete Laravel que conecta cualquier proyecto con SUNAT para facturación electrónica peruana. Soporta envío directo, OSE y PSE.",
    "keywords": ["laravel", "sunat", "facturacion", "electronica", "peru", "ose", "pse", "cpe", "factura"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Raúl García",
            "email": "sh.raul.jgb@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-soap": "*",
        "ext-dom": "*",
        "ext-openssl": "*",
        "ext-zip": "*",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "robrichards/xmlseclibs": "^3.1"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "RashArt\\SunatSender\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RashArt\\SunatSender\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RashArt\\SunatSender\\SunatSenderServiceProvider"
            ],
            "aliases": {
                "SunatSender": "RashArt\\SunatSender\\Facades\\SunatSender"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}