{
    "name": "rashart/sunat-sender",
    "description": "Paquete que conecta una aplicación con SUNAT utilizando envio directo como OSE o PSE, con posibilidad de extender proveedores",
    "keywords": ["laravel", "sunat", "facturacion", "electronica", "peru", "ose", "pse"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Raúl García",
            "email": "sh.raul.jgb@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "RashArt\\SunatSender\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RashArt\\SunatSender\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RashArt\\SunatSender\\SunatSenderServiceProvider"
            ],
            "aliases": {
                "SunatSender": "RashArt\\SunatSender\\Facades\\SunatSender"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
